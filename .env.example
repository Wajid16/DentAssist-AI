# ============================================
# DentAssist AI — Environment Variables
# ============================================
# Copy this to .env and fill in your values

# --- LLM ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- N8N Webhook URLs ---
# After importing workflows in N8N, copy the webhook URLs here
# Each workflow has a unique webhook URL shown in N8N's Webhook node
N8N_BOOKING_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/dentassist-booking
N8N_EMERGENCY_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/dentassist-emergency
N8N_LOG_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/dentassist-log

# --- Twilio (set in N8N environment variables) ---
# TWILIO_PHONE_NUMBER=+12085550123
# ONCALL_DENTIST_PHONE=+12085550199
