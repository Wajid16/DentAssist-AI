      "parameters": {
        "jsCode": "// Normalize input from either trigger (Execute Workflow OR Webhook)\nconst raw = $input.item.json;\n\n// If from webhook, data is nested in .body\nconst d = raw.body || raw;\n\n// Support both old field names (intent/service_needed/preferred_datetime)\n// and new field names (action/service_type/start_time)\nconst action = d.action || d.intent || 'book';\nconst startTime = d.start_time || d.preferred_datetime || '';\n\n// Auto-calculate end_time if not provided (default 1 hour appointment)\nlet endTime = d.end_time || '';\nif (!endTime && startTime) {\n  const start = new Date(startTime);\n  start.setHours(start.getHours() + 1);\n  endTime = start.toISOString();\n}\n\n// Generate idempotency key if not provided\nconst idempotencyKey = d.idempotency_key || \n  `${String(d.patient_phone || '')}-${startTime}`.replace(/[^a-zA-Z0-9-]/g, '-');\n\nreturn [{\n  json: {\n    action,\n    channel: d.channel || 'chat',\n    idempotency_key: idempotencyKey,\n    patient_name: d.patient_name || '',\n    patient_phone: String(d.patient_phone || ''),\n    patient_email: d.patient_email || '',\n    service_type: d.service_type || d.service_needed || '',\n    start_time: startTime,\n    end_time: endTime,\n    timezone: d.timezone || 'America/New_York',\n    calendar_event_id: d.calendar_event_id || d.event_id || '',\n    appointment_id: d.appointment_id || ''\n  }\n}];"
      },
