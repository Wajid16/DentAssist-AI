    {
      "parameters": {
        "jsCode": "const appointments = $input.all().map(i => i.json);\nconst ctx = $('Merge Patient ID').first().json;\n\nconst hasAppts = appointments.length > 0 && appointments[0].appointment_id;\n\nconst apptList = hasAppts\n  ? appointments.map(a =>\n      DateTime.fromISO(a.start_time).toFormat('EEEE MMM d') + ' at ' +\n      DateTime.fromISO(a.start_time).toFormat('h:mm a') + ' - ' + a.service_type\n    ).join(', ')\n  : 'No upcoming appointments found';\n\nreturn [{\n  json: {\n    success: true,\n    action: 'read',\n    appointments: hasAppts ? appointments : [],\n    count: hasAppts ? appointments.length : 0,\n    message_voice: hasAppts\n      ? `I found ${appointments.length} appointment${appointments.length > 1 ? 's' : ''} for you. The next one is on ${DateTime.fromISO(appointments[0].start_time).toFormat('EEEE MMMM d')} at ${DateTime.fromISO(appointments[0].start_time).toFormat('h:mm a')} for ${appointments[0].service_type}.`\n      : 'I could not find any upcoming appointments for your phone number.',\n    message_chat: hasAppts\n      ? `Found **${appointments.length}** upcoming appointment(s):\\n\\n` +\n        appointments.map((a, i) => `${i+1}. **${a.service_type}** — ${DateTime.fromISO(a.start_time).toFormat('EEEE, MMM d')} at ${DateTime.fromISO(a.start_time).toFormat('h:mm a')} (${a.status})`).join('\\n')\n      : '📭 No upcoming appointments found for your phone number.',\n    next_action: null\n  }\n}];"
      },
