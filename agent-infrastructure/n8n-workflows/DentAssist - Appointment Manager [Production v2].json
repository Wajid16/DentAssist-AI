        "message": "=<div style='font-family:Arial,sans-serif;max-width:600px;'><h2 style='color:#2563eb;'>Your Appointment is Confirmed!</h2><p>Hi {{ $json.patient_name }},</p><p>Your appointment has been successfully booked.</p><table style='border-collapse:collapse;width:100%;margin:20px 0;'><tr style='background:#f0f4ff;'><td style='padding:12px;border:1px solid #ddd;font-weight:bold;'>Service</td><td style='padding:12px;border:1px solid #ddd;'>{{ $json.service_type }}</td></tr><tr><td style='padding:12px;border:1px solid #ddd;font-weight:bold;'>Date & Time</td><td style='padding:12px;border:1px solid #ddd;'>{{ DateTime.fromISO($json.start_time).toFormat('EEEE, MMMM d, yyyy') }} at {{ DateTime.fromISO($json.start_time).toFormat('h:mm a') }}</td></tr><tr style='background:#f0f4ff;'><td style='padding:12px;border:1px solid #ddd;font-weight:bold;'>Location</td><td style='padding:12px;border:1px solid #ddd;'>305 W Idaho St, Boise, ID</td></tr><tr><td style='padding:12px;border:1px solid #ddd;font-weight:bold;'>Confirmation #</td><td style='padding:12px;border:1px solid #ddd;'>{{ $json.appointment_id }}</td></tr></table><p>A calendar invite has been sent to this email. To reschedule or cancel, please call (208) 555-0123.</p><p style='color:#666;font-size:12px;'>— Bright Smile Dental via DentAssist AI</p></div>",
