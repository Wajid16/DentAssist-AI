        "jsCode": "const gcalItems = $input.all();\nconst parentData = $('Merge Patient ID').first().json;\n\n// Exclude the current event being rescheduled from conflict check\nconst conflicts = gcalItems.filter(item =>\n  item.json && item.json.id && item.json.id !== parentData.calendar_event_id\n);\nconst slotTaken = conflicts.length > 0;\n\nreturn [{\n  json: {\n    ...parentData,\n    slot_available: !slotTaken,\n    conflicting_event: slotTaken ? (conflicts[0].json.summary || 'Existing appointment') : null\n  }\n}];"
